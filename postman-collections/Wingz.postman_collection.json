		{
			"name": "Ride Sorting — Distance",
			"item": [
				{
					"name": "[HAPPY PATH] Sort by distance ASC",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Response has paginated results\", function () {",
									"    const json = pm.response.json();",
									"    pm.expect(json).to.have.property('results');",
									"    pm.expect(json.results).to.be.an('array');",
									"});",
									"",
									"pm.test(\"Each ride has todays_ride_events field\", function () {",
									"    const results = pm.response.json().results;",
									"    results.forEach(ride => {",
									"        pm.expect(ride).to.have.property('todays_ride_events');",
									"    });",
									"});",
									"",
									"pm.test(\"Rides are sorted by distance ASC (nearest first)\", function () {",
									"    const results = pm.response.json().results;",
									"    if (results.length > 1) {",
									"        for (let i = 0; i < results.length - 1; i++) {",
									"            pm.expect(results[i].distance_to_pickup).to.be.at.most(results[i + 1].distance_to_pickup);",
									"        }",
									"    }",
									"});"
								]
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "{{access_token}}", "type": "text" }],
